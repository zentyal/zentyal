<%args>
@paths        => ()
$sambaStatus => 0
$mailfilterStatus => 0
</%args>

% if (scalar(@paths)) {
% foreach my $path (@paths) {
<% $path %>/** r,
% }
% }

% if ($sambaStatus) {
# Allow clamd to talk to Winbind
/run/samba/winbindd/pipe rw,
% }

% if ($mailfilterStatus) {
# Allow clamd to talk to Amavis
/var/lib/amavis/** r,
% }
