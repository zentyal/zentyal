# Script: save-license-data
#
#   Reads JSON license data from stdin and saves it to Redis via
#   EBox::GlobalImpl::saveLicenseData(). This avoids shell escaping
#   issues when passing data that contains special characters (like
#   bcrypt hashes with $ signs).
#
#   Usage: echo '{"license_key":"...","license_type":"..."}' | save-license-data

use strict;
use warnings;

use EBox;
use EBox::Global;
use JSON::XS;

EBox::init();

my $json_input = do { local $/; <STDIN> };
chomp($json_input);

unless ($json_input) {
    print STDERR "Error: No JSON data received on stdin\n";
    exit 1;
}

my $data;
eval {
    $data = decode_json($json_input);
};
if ($@) {
    print STDERR "Error: Invalid JSON input: $@\n";
    exit 1;
}

my $global = EBox::Global->getInstance();
$global->saveLicenseData($data);

exit 0;
