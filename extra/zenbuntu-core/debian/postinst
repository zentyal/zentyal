#!/bin/bash

ZENTYAL_VERSION='8.1'
LOG=/var/tmp/zentyal-installer.log

# replace motd
cp /usr/share/zenbuntu-core/motd.tail /etc/motd.tail

# Import archive key to avoid warnings
if [[ ! -f "/etc/apt/trusted.gpg.d/zentyal-${ZENTYAL_VERSION}-packages-org.asc" ]]
then
    cp /usr/share/zenbuntu-core/zentyal-${ZENTYAL_VERSION}-packages-org.asc /etc/apt/trusted.gpg.d/zentyal-${ZENTYAL_VERSION}-packages-org.asc
fi

if [[ ! -f "/etc/apt/trusted.gpg.d/zentyal-${ZENTYAL_VERSION}-packages-com.asc" ]]
then
    cp /usr/share/zenbuntu-core/zentyal-${ZENTYAL_VERSION}-packages-com.asc /etc/apt/trusted.gpg.d/zentyal-${ZENTYAL_VERSION}-packages-com.asc
fi


ln -sf /usr/share/plymouth/themes/zentyal-text/zentyal-text.plymouth /etc/alternatives/text.plymouth

# Copy rc.local
cp /usr/share/zenbuntu-core/initial-boot.sh /etc/rc.local
